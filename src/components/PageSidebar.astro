---
import MobileTableOfContents from 'virtual:starlight/components/MobileTableOfContents';
import TableOfContents from 'virtual:starlight/components/TableOfContents';
import ReferenceSignals from './ReferenceSignals.astro';
import { siteMeta } from '../utils/site-meta.mjs';

const route = Astro.locals.starlightRoute;
const updatedLabel =
	route.lastUpdated instanceof Date
		? new Intl.DateTimeFormat('en-US', { dateStyle: 'medium' }).format(route.lastUpdated)
		: undefined;
---

{
	route.toc && (
		<div class="lg:sl-hidden" data-nosnippet>
			<MobileTableOfContents />
		</div>
	)
}

<div class="right-sidebar-panel sl-hidden lg:sl-block">
	<div class="right-sidebar-panel__inner">
		{route.toc && (
			<div data-nosnippet>
				<TableOfContents />
			</div>
		)}
		<ReferenceSignals />
		<section class="editorial-review" data-nosnippet>
			<h2>Editorial Review</h2>
			<p>
				This site publishes editorial reference pages for manufacturing teams evaluating real robot
				applications, robot classes, cell design, and rollout readiness.
			</p>
			<p>
				Reviewed by <strong>{siteMeta.editorialTeamName}</strong>
				{updatedLabel ? ` | Updated ${updatedLabel}` : ''}.
			</p>
			<p class="editorial-review__links">
				<a href="/about/">About</a>
				<span aria-hidden="true"> / </span>
				<a href="/editorial-policy/">Editorial Policy</a>
				<span aria-hidden="true"> / </span>
				<a href="/contact/">Contact</a>
			</p>
		</section>
	</div>
</div>
