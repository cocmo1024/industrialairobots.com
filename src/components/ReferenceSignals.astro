---
type RouteData = Record<string, unknown>;
import { siteMeta } from '../utils/site-meta.mjs';
type Signal = {
	label: string;
	value: string | string[];
	list?: boolean;
};

const route = Astro.locals.starlightRoute;
const data = (route.entry?.data ?? {}) as RouteData;

const keyQuestions =
	Array.isArray(data.keyQuestions) && data.keyQuestions.every((item) => typeof item === 'string')
		? data.keyQuestions
		: [];
const notFor =
	Array.isArray(data.notFor) && data.notFor.every((item) => typeof item === 'string')
		? data.notFor
		: [];
const updateTriggers =
	Array.isArray(data.updateTriggers) && data.updateTriggers.every((item) => typeof item === 'string')
		? data.updateTriggers
		: [];

const signals = [
	typeof data.problemSolved === 'string' && { label: 'Problem Solved', value: data.problemSolved },
	typeof data.readerTakeaway === 'string' && { label: 'What You Leave With', value: data.readerTakeaway },
	keyQuestions.length > 0 && { label: 'Key Questions', value: keyQuestions, list: true },
	notFor.length > 0 && { label: 'Usually A Poor Fit', value: notFor, list: true },
	updateTriggers.length > 0 && { label: 'Worth Revisiting When', value: updateTriggers, list: true },
	{ label: 'Reviewed By', value: siteMeta.editorialTeamName },
].filter(Boolean) as Signal[];
---

{
	signals.length > 0 && (
		<section class="reference-signals">
			<h2>Page Context</h2>
			<dl>
				{signals.map(({ label, value, list }) => (
					<div>
						<dt>{label}</dt>
						<dd>
							{
								list && Array.isArray(value) ? (
									<ul class="reference-signals__list">
										{value.map((item) => (
											<li>{item}</li>
										))}
									</ul>
								) : (
									<p class="reference-signals__text">
										{Array.isArray(value) ? value.join(', ') : value}
									</p>
								)
							}
						</dd>
					</div>
				))}
			</dl>
		</section>
	)
}
