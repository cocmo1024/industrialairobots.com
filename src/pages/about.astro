---
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
---

<Layout title={`About | ${SITE.title}`}>
  <Header />
  <Main pageTitle="About" pageDesc={`About ${SITE.title}`}>
    <div class="app-prose max-w-app">
      <p>
        Industrial AI Robots is an independent English-language publication covering industrial robot applications, AI vision systems, and automation deployment choices.
      </p>
      <p>
        The site is oriented toward practical industrial use cases, with an editorial preference for clear explanations of operations, integration, and implementation tradeoffs.
      </p>
    </div>
  </Main>
  <Footer />
</Layout>
