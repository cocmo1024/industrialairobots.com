---
import { getCollection } from 'astro:content';
import AdSlot from '../../components/AdSlot.astro';
import PostPreviewCard from '../../components/PostPreviewCard.astro';
import SidebarCard from '../../components/SidebarCard.astro';
import ClassicShell from '../../layouts/ClassicShell.astro';
import { SITE_DESCRIPTION, SITE_KEYWORDS, SITE_TITLE } from '../../consts';
import { sortPosts } from '../../utils/content';

const posts = sortPosts(await getCollection('blog'));
---

<ClassicShell
	title={`${SITE_TITLE} | Blog`}
	description={SITE_DESCRIPTION}
	pageTitle="Industrial AI robotics archive"
	pageIntro="Use the archive as the long-lived center of gravity for application-driven robotics coverage: machine vision, cobots, robotic cells, and deployment decisions."
	introLabel="Archive"
	keywords={[...SITE_KEYWORDS, 'robotics archive', 'industrial ai archive']}
	breadcrumbs={[
		{ name: 'Home', path: '/' },
		{ name: 'Applications', path: '/blog/' },
	]}
>
	<Fragment slot="left-rail">
		<SidebarCard title="Archive Goal" eyebrow="Evergreen">
			<p>
				The best pages here will keep ranking because they answer practical questions around
				deployment, safety, compute, ROI, and vendor fit.
			</p>
		</SidebarCard>
	</Fragment>

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">All Entries</p>
				<h3>Latest industrial AI robotics coverage</h3>
			</div>
		</div>

		<div class="post-stream">
			{posts.length === 0 ? (
				<p>No posts yet. The archive is ready for robotic cell guides, vendor comparisons, and application explainers.</p>
			) : (
				posts.map((post, index) => (
					<>
						<PostPreviewCard post={post} featured={index === 0} />
						{
							index === 0 && (
								<AdSlot
									slotId="archive-inline-robotics"
									format="inline"
									headline="Inline robotics partner slot"
									note="After the lead article, this is a natural location for integrator partners, vision system promos, or robotics event campaigns."
								/>
							)
						}
					</>
				))
			)}
		</div>
	</section>
</ClassicShell>
